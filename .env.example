# Authentication
# Leave empty only for local development.
ENVIRONMENT=development
API_BEARER_TOKEN=
# Example:
# API_BEARER_TOKEN=change-this-secret-token

# ESS Gateway trust. Mount a public-only P-256 JWKS; the private signer never enters this service.
GATEWAY_ASSERTION_REQUIRED=false
ALLOW_UNSIGNED_IDENTITY_HEADERS=true
GATEWAY_ASSERTION_ISSUER=
GATEWAY_ASSERTION_AUDIENCE=
GATEWAY_ALLOWED_TENANTS=
GATEWAY_ASSERTION_ALLOWED_ALGORITHMS=ES256
GATEWAY_JWKS_PATH=
GATEWAY_ASSERTION_MAX_TTL_SECONDS=90
GATEWAY_ASSERTION_CLOCK_SKEW_SECONDS=5
GATEWAY_JTI_REPLAY_TTL_SECONDS=120
REQUIRE_RECENT_DEVICE_ATTESTATION=false
DEVICE_ATTESTATION_MAX_AGE_SECONDS=120
ALLOWED_ATTESTATION_PROVIDERS=play_integrity,app_attest
ALLOWED_ATTESTATION_VERDICTS=MEETS_DEVICE_INTEGRITY,VALID
ALLOWED_ATTESTATION_APP_IDENTIFIERS=

# ESS persistence and sensitive-data protection
ESS_DATABASE_PATH=data/ess.sqlite3
# Preferred SQLAlchemy URL. Leave empty locally to use ESS_DATABASE_PATH.
DATABASE_URL=
DATABASE_AUTO_CREATE=true
ALLOW_SQLITE_IN_PRODUCTION=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_CONNECT_TIMEOUT_SECONDS=10
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIOMETRIC_ENCRYPTION_KEY=
BIOMETRIC_ENCRYPTION_KEY_VERSION=1
# Backend/admin-issued recovery token; never bundle this in the mobile app.
DEVICE_RESET_TOKEN=
CORS_ALLOWED_ORIGINS=*
ENABLE_API_DOCS=true
CLIENT_VALIDATION_RATE_LIMIT_PER_MINUTE=30
MAX_IMAGE_MB=5
MAX_IMAGE_PIXELS=20000000
LOG_LEVEL=INFO
MODEL_PROVIDER=mock
BACKEND_VERSION=phase-5

# Mock local testing
DETECTOR_PROVIDER=mock
RECOGNIZER_PROVIDER=mock

# Real local testing
# DETECTOR_PROVIDER=yunet
# RECOGNIZER_PROVIDER=arcface_onnx
# YUNET_MODEL_PATH=models/face_detection_yunet_2023mar.onnx
# ARCFACE_MODEL_PATH=models/face-recognition-resnet100-arcface.onnx

YUNET_MODEL_PATH=models/face_detection_yunet_2023mar.onnx
YUNET_SCORE_THRESHOLD=0.85
YUNET_NMS_THRESHOLD=0.3
YUNET_TOP_K=5000
MIN_FACE_SIZE=20
MAX_IMAGE_DIMENSION=640
ARCFACE_MODEL_PATH=models/face-recognition-resnet100-arcface.onnx
ARCFACE_INPUT_SIZE=112
ARCFACE_EMBEDDING_DIM=512
ARCFACE_NORMALIZATION=raw_rgb_0_255
ARCFACE_USE_GPU=false
ONNX_PROVIDERS=CPUExecutionProvider
# Optional emergency override. Leave unset to use the model calibration profile.
# MATCH_THRESHOLD=0.40
CALIBRATION_DIR=calibration
REQUIRE_CALIBRATION=true
USE_CALIBRATED_THRESHOLD=true
RETURN_EMBEDDINGS_DEFAULT=false
ALLOW_EMBEDDING_RETURN=false

# Device possession proof. Private keys stay in Android Keystore/iOS secure storage.
DEVICE_PROOF_REQUIRED=true
DEVICE_CHALLENGE_TTL_SECONDS=60
ALLOW_LEGACY_DEVICE_ID_ONLY=false

# Liveness/replay. disabled/mock cannot satisfy production startup validation.
LIVENESS_REQUIRED=false
LIVENESS_PROVIDER=disabled
LIVENESS_CHALLENGE_TTL_SECONDS=90
LIVENESS_MAX_ATTEMPTS=3
LIVENESS_REQUIRED_CAPTURE_COUNT=3
LIVENESS_ASSERTION_SECRET=
ALLOW_LEGACY_SINGLE_IMAGE_VERIFICATION=false
REPLAY_WINDOW_SECONDS=600
CAPTURE_MAX_AGE_SECONDS=120

# Abuse control. Use redis for multiple replicas.
RATE_LIMIT_BACKEND=memory
REDIS_URL=
APP_REPLICA_COUNT=1
CLIENT_CREATE_LIMIT_PER_HOUR=20
FACE_VERIFY_LIMIT_PER_MINUTE=5
FACE_REGISTER_LIMIT_PER_HOUR=3
FACE_LIFECYCLE_LIMIT_PER_HOUR=3
LIVENESS_CHALLENGE_LIMIT_PER_MINUTE=5
DEVICE_VERIFY_LIMIT_PER_MINUTE=10
DEVICE_REGISTER_LIMIT_PER_HOUR=5
DEVICE_RESET_LIMIT_PER_HOUR=3
DEVICE_ROTATE_LIMIT_PER_HOUR=3
DEVICE_REVOKE_LIMIT_PER_HOUR=3
LOW_LEVEL_FACE_LIMIT_PER_MINUTE=30
FAILED_FACE_ATTEMPT_WINDOW_SECONDS=600
FAILED_FACE_ATTEMPT_LIMIT=5
FACE_COOLDOWN_SECONDS=900
AUDIT_HASH_KEY=

# Production calibration approval. Values must be selected by the risk owner.
REQUIRE_APPROVED_DEPLOYMENT_CALIBRATION=false
APPROVED_CALIBRATION_PROFILE_PATH=
# DEPLOYMENT_MIN_GENUINE_PAIRS=
# DEPLOYMENT_MIN_IMPOSTOR_PAIRS=
# DEPLOYMENT_TARGET_FMR=
# DEPLOYMENT_MAX_FNMR_AT_TARGET_FMR=
# DEPLOYMENT_MAX_FAILURE_TO_ACQUIRE_RATE=
# DEPLOYMENT_MAX_P95_LATENCY_MS=
ALLOW_API_DOCS_IN_PRODUCTION=false
MOBILEFACENET_MODEL_PATH=models/mobilefacenet.onnx
MOBILEFACENET_INPUT_SIZE=112
MOBILEFACENET_EMBEDDING_DIM=512
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_CTX_ID=-1
BENCHMARK_OUTPUT_DIR=benchmark_reports
BENCHMARK_TARGET_FMR_VALUES=1e-3,1e-4,1e-5
BENCHMARK_DEFAULT_MODELS=arcface_onnx,mobilefacenet_onnx
BENCHMARK_SAVE_PER_PAIR=true
