# Authentication
# Leave empty only for local development.
API_BEARER_TOKEN=
# Example:
# API_BEARER_TOKEN=change-this-secret-token

# ESS persistence and sensitive-data protection
ESS_DATABASE_PATH=data/ess.sqlite3
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIOMETRIC_ENCRYPTION_KEY=
# Backend/admin-issued recovery token; never bundle this in the mobile app.
DEVICE_RESET_TOKEN=
MAX_IMAGE_MB=8
LOG_LEVEL=INFO
MODEL_PROVIDER=mock
BACKEND_VERSION=phase-4.1

# Mock local testing
DETECTOR_PROVIDER=mock
RECOGNIZER_PROVIDER=mock

# Real local testing
# DETECTOR_PROVIDER=yunet
# RECOGNIZER_PROVIDER=arcface_onnx
# YUNET_MODEL_PATH=models/face_detection_yunet_2023mar.onnx
# ARCFACE_MODEL_PATH=models/face-recognition-resnet100-arcface.onnx

YUNET_MODEL_PATH=models/face_detection_yunet_2023mar.onnx
YUNET_SCORE_THRESHOLD=0.85
YUNET_NMS_THRESHOLD=0.3
YUNET_TOP_K=5000
MIN_FACE_SIZE=20
MAX_IMAGE_DIMENSION=640
ARCFACE_MODEL_PATH=models/face-recognition-resnet100-arcface.onnx
ARCFACE_INPUT_SIZE=112
ARCFACE_EMBEDDING_DIM=512
ARCFACE_NORMALIZATION=raw_0_255
ARCFACE_USE_GPU=false
ONNX_PROVIDERS=CPUExecutionProvider
MATCH_THRESHOLD=0.40
RETURN_EMBEDDINGS_DEFAULT=false
ALLOW_EMBEDDING_RETURN=false
MOBILEFACENET_MODEL_PATH=models/mobilefacenet.onnx
MOBILEFACENET_INPUT_SIZE=112
MOBILEFACENET_EMBEDDING_DIM=512
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_CTX_ID=-1
BENCHMARK_OUTPUT_DIR=benchmark_reports
BENCHMARK_TARGET_FMR_VALUES=1e-3,1e-4,1e-5
BENCHMARK_DEFAULT_MODELS=arcface_onnx,mobilefacenet_onnx
BENCHMARK_SAVE_PER_PAIR=true
