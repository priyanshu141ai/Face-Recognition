# Placeholder-only Coolify staging runtime configuration.
# Replace every <...> value in Coolify. Never commit a populated copy.

ENVIRONMENT=staging
BACKEND_VERSION=<staging-release-id>
ENABLE_API_DOCS=false
ALLOW_API_DOCS_IN_PRODUCTION=false
CORS_ALLOWED_ORIGINS=https://<ess-staging-domain>
LOG_LEVEL=INFO
MAX_IMAGE_MB=5
MAX_IMAGE_PIXELS=20000000

API_BEARER_TOKEN=<coolify-runtime-secret>
GATEWAY_ASSERTION_REQUIRED=true
ALLOW_UNSIGNED_IDENTITY_HEADERS=false
GATEWAY_ASSERTION_ISSUER=https://<ess-staging-domain>
GATEWAY_ASSERTION_AUDIENCE=face-api-staging
GATEWAY_ALLOWED_TENANTS=<allowed-staging-client-id>
GATEWAY_ASSERTION_ALLOWED_ALGORITHMS=ES256
GATEWAY_JWKS_PATH=/run/secrets/gateway-public.jwks.json
GATEWAY_ASSERTION_MAX_TTL_SECONDS=90
GATEWAY_ASSERTION_CLOCK_SKEW_SECONDS=5
GATEWAY_JTI_REPLAY_TTL_SECONDS=120
REQUIRE_RECENT_DEVICE_ATTESTATION=false
DEVICE_ATTESTATION_MAX_AGE_SECONDS=120
ALLOWED_ATTESTATION_PROVIDERS=play_integrity,app_attest
ALLOWED_ATTESTATION_VERDICTS=MEETS_DEVICE_INTEGRITY,VALID
ALLOWED_ATTESTATION_APP_IDENTIFIERS=<android-package>,<ios-bundle-id>
BIOMETRIC_ENCRYPTION_KEY=<valid-fernet-key-from-secret-manager>
BIOMETRIC_ENCRYPTION_KEY_VERSION=1
DEVICE_RESET_TOKEN=<coolify-runtime-secret>
AUDIT_HASH_KEY=<coolify-runtime-secret>

DETECTOR_PROVIDER=yunet
RECOGNIZER_PROVIDER=arcface_onnx
YUNET_MODEL_PATH=/app/models/face_detection_yunet_2023mar.onnx
ARCFACE_MODEL_PATH=/app/models/face-recognition-resnet100-arcface.onnx
ARCFACE_SHA256=f3a6bc281e72f88862f5748b53be3d76b3b48f8f1ab1f4a537941bdc4e1b01da
ONNX_PROVIDERS=CPUExecutionProvider

DATABASE_URL=postgresql+psycopg://<user>:<password>@<coolify-internal-postgres-host>:5432/<database>
DATABASE_AUTO_CREATE=false
ALLOW_SQLITE_IN_PRODUCTION=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_CONNECT_TIMEOUT_SECONDS=10

RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://:<password>@<coolify-internal-redis-host>:6379/0
APP_REPLICA_COUNT=1
CLIENT_VALIDATION_RATE_LIMIT_PER_MINUTE=30
CLIENT_CREATE_LIMIT_PER_HOUR=20
FACE_VERIFY_LIMIT_PER_MINUTE=5
FACE_REGISTER_LIMIT_PER_HOUR=3
FACE_LIFECYCLE_LIMIT_PER_HOUR=3
LIVENESS_CHALLENGE_LIMIT_PER_MINUTE=5
DEVICE_VERIFY_LIMIT_PER_MINUTE=10
DEVICE_REGISTER_LIMIT_PER_HOUR=5
DEVICE_RESET_LIMIT_PER_HOUR=3
DEVICE_ROTATE_LIMIT_PER_HOUR=3
DEVICE_REVOKE_LIMIT_PER_HOUR=3
LOW_LEVEL_FACE_LIMIT_PER_MINUTE=30
FAILED_FACE_ATTEMPT_WINDOW_SECONDS=600
FAILED_FACE_ATTEMPT_LIMIT=5
FACE_COOLDOWN_SECONDS=900

DEVICE_PROOF_REQUIRED=true
DEVICE_CHALLENGE_TTL_SECONDS=60
ALLOW_LEGACY_DEVICE_ID_ONLY=false

# STAGING ONLY: no validated liveness provider is available. The legacy flag
# permits one-probe verification only; registration still requires three angles.
LIVENESS_REQUIRED=false
LIVENESS_PROVIDER=disabled
ALLOW_LEGACY_SINGLE_IMAGE_VERIFICATION=true
LIVENESS_CHALLENGE_TTL_SECONDS=90
LIVENESS_MAX_ATTEMPTS=3
LIVENESS_REQUIRED_CAPTURE_COUNT=3
REPLAY_WINDOW_SECONDS=600
CAPTURE_MAX_AGE_SECONDS=120

# Existing LFW research profile only; it is not production-approved calibration.
REQUIRE_CALIBRATION=true
USE_CALIBRATED_THRESHOLD=true
CALIBRATION_DIR=/app/calibration
REQUIRE_APPROVED_DEPLOYMENT_CALIBRATION=false
APPROVED_CALIBRATION_PROFILE_PATH=

ALLOW_EMBEDDING_RETURN=false
RETURN_EMBEDDINGS_DEFAULT=false
